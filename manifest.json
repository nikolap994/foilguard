{
  "manifest_version": 3,
  "name": "FoilGuard",
  "version": "0.4.0",
  "description": "Blocks typosquatting, homoglyphs, combosquatting, and newly-registered domain attacks before the page loads. Enterprise MDM policy support. No API key.",
  "permissions": ["tabs", "storage", "webNavigation", "contextMenus", "notifications", "alarms", "sidePanel", "history"],
  "storage": {
    "managed_schema": "managed-schema.json"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+Shift+F" },
      "description": "Open FoilGuard"
    }
  },
  "options_page": "src/options/options.html",
  "browser_specific_settings": {
    "gecko": {
      "id": "foilguard@nikolap994.com",
      "strict_min_version": "109.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/popup-guard.ts"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/foilguard-16.png",
      "48": "icons/foilguard-48.png",
      "128": "icons/foilguard-128.png"
    }
  },
  "icons": {
    "16": "icons/foilguard-16.png",
    "48": "icons/foilguard-48.png",
    "128": "icons/foilguard-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
